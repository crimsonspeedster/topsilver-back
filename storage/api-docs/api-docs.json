{
    "openapi": "3.0.0",
    "info": {
        "title": "API for TopSilver project",
        "description": "API documentation for TopSilver project",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Local development server"
        }
    ],
    "paths": {
        "/api/v1/me/bonuses": {
            "get": {
                "tags": [
                    "User"
                ],
                "summary": "Get user bonuses",
                "description": "Returns the current user's active and future bonuses",
                "operationId": "25023c256c68bce1f7dfe4f5b6e31afb",
                "responses": {
                    "200": {
                        "description": "Successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "properties": {
                                                "active_total": {
                                                    "type": "number",
                                                    "format": "float",
                                                    "example": 125.5
                                                },
                                                "active_bonuses": {
                                                    "type": "array",
                                                    "items": {
                                                        "$ref": "#/components/schemas/BonusSchema"
                                                    }
                                                },
                                                "future_bonuses": {
                                                    "type": "array",
                                                    "items": {
                                                        "$ref": "#/components/schemas/BonusSchema"
                                                    }
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/logout": {
            "post": {
                "tags": [
                    "User"
                ],
                "summary": "Logout current user",
                "description": "Invalidate current access token",
                "operationId": "c1b1275551c26048c23d4f149de328c5",
                "responses": {
                    "200": {
                        "description": "Successfully logged out",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Logged out successfully"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/me/orders/{id}": {
            "get": {
                "tags": [
                    "User"
                ],
                "summary": "Get user order by id",
                "description": "Returns the current user's order by id",
                "operationId": "4be764900f2439278b9efefecb19ecc2",
                "responses": {
                    "200": {
                        "description": "Successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/OrdersSchema"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/me/orders": {
            "get": {
                "tags": [
                    "User"
                ],
                "summary": "Get user orders",
                "description": "Returns the current user's orders",
                "operationId": "1e38dc3ecf0a0843782d10421f6ac618",
                "responses": {
                    "200": {
                        "description": "Successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "properties": {
                                                "orders": {
                                                    "type": "array",
                                                    "items": {
                                                        "$ref": "#/components/schemas/OrdersSchema"
                                                    }
                                                },
                                                "pagination": {
                                                    "$ref": "#/components/schemas/PaginationSchema"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/me": {
            "get": {
                "tags": [
                    "User"
                ],
                "summary": "Get authenticated user",
                "description": "Returns current authenticated user with profile",
                "operationId": "f99052b8c73e01256d9032b2af0c8295",
                "responses": {
                    "200": {
                        "description": "Current user data",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/ProfileSchema"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "RegisterRequestSchema": {
                "required": [
                    "email",
                    "phone",
                    "password",
                    "password_confirmation",
                    "name",
                    "surname"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "example": "test@mail.com"
                    },
                    "phone": {
                        "type": "string",
                        "example": "380630000000"
                    },
                    "password": {
                        "type": "string",
                        "example": "Password123"
                    },
                    "password_confirmation": {
                        "type": "string",
                        "example": "Password123"
                    },
                    "name": {
                        "type": "string",
                        "example": "John"
                    },
                    "surname": {
                        "type": "string",
                        "example": "Doe"
                    },
                    "middle_name": {
                        "type": "string",
                        "example": "Alexandrian",
                        "nullable": true
                    },
                    "about": {
                        "type": "string",
                        "example": "Lorem Ipsum",
                        "nullable": true
                    },
                    "sex": {
                        "type": "string",
                        "example": "male",
                        "nullable": true
                    },
                    "dob": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-02-28",
                        "nullable": true
                    },
                    "city_id": {
                        "type": "integer",
                        "example": 1,
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "UpdateProfileRequestSchema": {
                "properties": {
                    "email": {
                        "type": "string",
                        "example": "test@mail.com",
                        "nullable": true
                    },
                    "phone": {
                        "type": "string",
                        "example": "380630000000",
                        "nullable": true
                    },
                    "password": {
                        "type": "string",
                        "example": "Password123",
                        "nullable": true
                    },
                    "password_confirmation": {
                        "type": "string",
                        "example": "Password123",
                        "nullable": true
                    },
                    "name": {
                        "type": "string",
                        "example": "John",
                        "nullable": true
                    },
                    "surname": {
                        "type": "string",
                        "example": "Doe",
                        "nullable": true
                    },
                    "middle_name": {
                        "type": "string",
                        "example": "Alexandrian",
                        "nullable": true
                    },
                    "about": {
                        "type": "string",
                        "example": "Lorem Ipsum",
                        "nullable": true
                    },
                    "sex": {
                        "type": "string",
                        "example": "male",
                        "nullable": true
                    },
                    "dob": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-02-28",
                        "nullable": true
                    },
                    "city_id": {
                        "type": "integer",
                        "example": 1,
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "BonusSchema": {
                "properties": {
                    "amount": {
                        "type": "string",
                        "example": "2400.00"
                    },
                    "accrual_from": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-04-14T10:00:00Z"
                    },
                    "available_from": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-04-16T10:00:00Z"
                    },
                    "expires_at": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-04-20T10:00:00Z"
                    }
                },
                "type": "object"
            },
            "CitySchema": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Kyiv"
                    },
                    "region": {
                        "$ref": "#/components/schemas/RegionSchema"
                    }
                },
                "type": "object"
            },
            "OrderItemSchema": {
                "properties": {
                    "product_name": {
                        "type": "string",
                        "example": "iPhone 17"
                    },
                    "product_image": {
                        "type": "string",
                        "example": "https://example.com/image.jpg"
                    },
                    "product_price": {
                        "type": "string",
                        "example": "1000.00"
                    },
                    "quantity": {
                        "type": "integer",
                        "example": 2
                    },
                    "total": {
                        "type": "string",
                        "example": "2000.00"
                    },
                    "product_variant": {
                        "type": "object",
                        "nullable": true
                    },
                    "product": {
                        "oneOf": [
                            {
                                "$ref": "#/components/schemas/ProductCollectionSchema"
                            }
                        ],
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "OrdersSchema": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "status": {
                        "type": "string",
                        "example": "pending"
                    },
                    "subtotal": {
                        "type": "string",
                        "example": "100.00"
                    },
                    "total": {
                        "type": "string",
                        "example": "120.00"
                    },
                    "paid_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "notes": {
                        "type": "string",
                        "example": "Call before delivery",
                        "nullable": true
                    },
                    "first_name": {
                        "type": "string",
                        "example": "John"
                    },
                    "last_name": {
                        "type": "string",
                        "example": "Doe"
                    },
                    "middle_name": {
                        "type": "string",
                        "example": "Alex",
                        "nullable": true
                    },
                    "phone": {
                        "type": "string",
                        "example": "380501234567"
                    },
                    "email": {
                        "type": "string",
                        "example": "test@gmail.com",
                        "nullable": true
                    },
                    "payment_type": {
                        "type": "string",
                        "example": "cod"
                    },
                    "payment_data": {
                        "type": "object",
                        "nullable": true
                    },
                    "shipping_type": {
                        "type": "string",
                        "example": "nova_poshta"
                    },
                    "shipping_data": {
                        "type": "object",
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "items": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/OrderItemSchema"
                        }
                    }
                },
                "type": "object"
            },
            "PaginationSchema": {
                "properties": {
                    "total_pages": {
                        "type": "integer",
                        "example": 10
                    },
                    "current_page": {
                        "type": "integer",
                        "example": 1
                    },
                    "per_page": {
                        "type": "integer",
                        "example": 15
                    },
                    "total_items": {
                        "type": "integer",
                        "example": 150
                    },
                    "has_more_pages": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "ProductCollectionSchema": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "title": {
                        "type": "string",
                        "example": "iPhone 17"
                    },
                    "slug": {
                        "type": "string",
                        "example": "iphone-17",
                        "nullable": true
                    },
                    "price": {
                        "type": "string",
                        "example": "999.99"
                    },
                    "price_on_sale": {
                        "type": "string",
                        "example": "899.99",
                        "nullable": true
                    },
                    "type": {
                        "type": "string",
                        "example": "simple"
                    }
                },
                "type": "object"
            },
            "ProfileSchema": {
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "John"
                    },
                    "surname": {
                        "type": "string",
                        "example": "Smith"
                    },
                    "middle_name": {
                        "type": "string",
                        "example": "Alexandrian",
                        "nullable": true
                    },
                    "about": {
                        "type": "string",
                        "example": "Lorem Ipsum",
                        "nullable": true
                    },
                    "sex": {
                        "type": "string",
                        "example": "male",
                        "nullable": true
                    },
                    "dob": {
                        "type": "string",
                        "format": "date",
                        "nullable": true
                    },
                    "city": {
                        "oneOf": [
                            {
                                "$ref": "#/components/schemas/CitySchema"
                            }
                        ],
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "RegionSchema": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Kyiv region"
                    }
                },
                "type": "object"
            },
            "UserSchema": {
                "properties": {
                    "email": {
                        "type": "string",
                        "example": "test@gmail.com"
                    },
                    "phone": {
                        "type": "string",
                        "example": "380630000000"
                    },
                    "profile": {
                        "$ref": "#/components/schemas/ProfileSchema"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "apiKey",
                "description": "Enter token in format: Bearer {token}",
                "name": "Authorization",
                "in": "header"
            }
        }
    },
    "tags": [
        {
            "name": "User",
            "description": "User"
        }
    ]
}